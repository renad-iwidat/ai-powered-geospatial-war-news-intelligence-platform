# Database Configuration (Hosted on Render)
# Example: postgresql://user:password@host:port/database
DATABASE_URL=

# News Configuration
NEWS_VIEW_NAME=vw_news_ar_feed

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Docker Port Configuration
# Backend port inside container is always 7235
# Frontend port inside container is always 3001
BACKEND_PORT=7235
FRONTEND_PORT=3001

# CORS Configuration (comma-separated)
# Example: http://localhost:3001,http://frontend:3001
CORS_ORIGINS_STR=http://localhost:3001,http://frontend:3001

# Scheduler Configuration
# Used by scripts/run_scheduler.py and docker-compose.scheduler.yml
# For Docker: http://backend:7235
# For Local: http://localhost:7235
API_BASE_URL=http://backend:7235
